# Ignore everything by default, then re-allow only the public agent package.
*

# Root public files
!.gitignore
!README.md
!CHALLENGE.md
!requirements.txt
!.env.example

# Keep the ai-sales Hermes profile skeleton, not private Hermes runtime
!.hermes/
.hermes/*
!.hermes/profiles/
.hermes/profiles/*
!.hermes/profiles/ai-sales/
.hermes/profiles/ai-sales/*
!.hermes/profiles/ai-sales/SOUL.md
!.hermes/profiles/ai-sales/profile.yaml

# Profile cron wrapper needed for daily orchestration setup
!.hermes/profiles/ai-sales/scripts/
.hermes/profiles/ai-sales/scripts/*
!.hermes/profiles/ai-sales/scripts/daily_orchestration_cron.py

# Only ai-sales custom skills, not all bundled Hermes skills
!.hermes/profiles/ai-sales/skills/
.hermes/profiles/ai-sales/skills/*
!.hermes/profiles/ai-sales/skills/ai-sales/
!.hermes/profiles/ai-sales/skills/ai-sales/**

# Public workspace docs/setup
!.hermes/profiles/ai-sales/workspace/
.hermes/profiles/ai-sales/workspace/*
!.hermes/profiles/ai-sales/workspace/README.md
!.hermes/profiles/ai-sales/workspace/CHALLENGE.md
!.hermes/profiles/ai-sales/workspace/requirements.txt
!.hermes/profiles/ai-sales/workspace/challenge-checklist.md
!.hermes/profiles/ai-sales/workspace/partner-brief-wella-professionals-fr.md

# Public workspace scripts
!.hermes/profiles/ai-sales/workspace/scripts/
!.hermes/profiles/ai-sales/workspace/scripts/**

# Public operating-model docs
!.hermes/profiles/ai-sales/workspace/company/
!.hermes/profiles/ai-sales/workspace/company/**
!.hermes/profiles/ai-sales/workspace/team-1-prospection-intelligence/
!.hermes/profiles/ai-sales/workspace/team-1-prospection-intelligence/**
!.hermes/profiles/ai-sales/workspace/team-2-outreach-engagement/
!.hermes/profiles/ai-sales/workspace/team-2-outreach-engagement/**
!.hermes/profiles/ai-sales/workspace/team-3-admin-rdv/
!.hermes/profiles/ai-sales/workspace/team-3-admin-rdv/**
!.hermes/profiles/ai-sales/workspace/team-4-content-marketing/
!.hermes/profiles/ai-sales/workspace/team-4-content-marketing/**
!.hermes/profiles/ai-sales/workspace/team-5-crm-orchestration/
!.hermes/profiles/ai-sales/workspace/team-5-crm-orchestration/**

# Demo: keep only sanitized reusable demo assets/scripts
!.hermes/profiles/ai-sales/workspace/demo/
.hermes/profiles/ai-sales/workspace/demo/*
!.hermes/profiles/ai-sales/workspace/demo/*.py
!.hermes/profiles/ai-sales/workspace/demo/runbook.md
!.hermes/profiles/ai-sales/workspace/demo/generic-company-demo-prompt.md

# Always private / generated / personal
.env
.env.*
!.env.example
*.pem
*.key
*.sqlite
*.db
*.db-wal
*.db-shm
*token*
*secret*
*credential*

.bash_history
.bashrc
.profile
.gitconfig
.claude.json
search.html
.ssh/
.config/
.local/
.pki/
.cache/
.npm/
.trae/
.trae-server/
.cua-driver/
.cua-driver-rs/
.ai_completion/

__pycache__/
*.pyc
.venv/
venv/
**/venv/
**/.venv/
.DS_Store

